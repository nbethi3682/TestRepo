from collections import defaultdict
import itertools

class ProbAgent(MovePlanningAgent):

    def __init__(self, width=4, height=4):
        super().__init__(width, height)

        # ---------------------------------------
        # BELIEF STATE VARIABLES
        # ---------------------------------------

        # Probability of pit in each cell
        # Initialize with prior pit probability (0.2 for all non-start cells)
        self.pit_probs = {
            (x, y): 0.2 if (x, y) != (0, 0) else 0.0
            for x in range(width)
            for y in range(height)
        }

        # Probability of Wumpus in each cell
        # Initially uniform among all non-start cells
        total_cells = width * height - 1
        uniform_prob = 1.0 / total_cells
        self.wumpus_probs = {
            (x, y): (uniform_prob if (x, y) != (0, 0) else 0.0)
            for x in range(width)
            for y in range(height)
        }

        # Wumpus gets removed if scream heard
        self.wumpus_alive = True

        # ---------------------------------------
        # PERCEPT HISTORY
        # ---------------------------------------

        self.breeze_map = {}    # cell → True/False
        self.stench_map = {}    # cell → True/False

        self.heard_scream = False
        self.arrow_used = False

        # ---------------------------------------
        # ACTION PLANNING + NAVIGATION
        # ---------------------------------------

        self.current_direction = "RIGHT"
        self.current_position = (0, 0)

        # Cells the agent considers "safe enough" by probability threshold
        self.known_safe = set([(0, 0)])

        # Cells that are not yet visited but candidates for exploration
        self.frontier = set()

        # Plan queue (generated via BFS)
        self.plan = []

        # Threshold: If move has >50% chance of death, agent gives up
        self.abort_threshold = 0.50

    # ----------------------------------------------------
    # HELPER: Update current position/direction
    # ----------------------------------------------------
    def update_agent_state(self, position, direction):
        self.current_position = tuple(position)
        self.current_direction = direction

    # ----------------------------------------------------
    # HELPER: List adjacent cells
    # ----------------------------------------------------
    def adjacent(self, cell):
        x, y = cell
        adj = []
        if x > 0: adj.append((x-1, y))
        if x < self.width-1: adj.append((x+1, y))
        if y > 0: adj.append((x, y-1))
        if y < self.height-1: adj.append((x, y+1))
        return adj

    # ----------------------------------------------------
    # HELPER: Mark a cell as 100% safe
    # ----------------------------------------------------
    def mark_safe(self, cell):
        self.known_safe.add(cell)
        self.pit_probs[cell] = 0.0
        self.wumpus_probs[cell] = 0.0

    # ----------------------------------------------------
    # HELPER: Remove Wumpus entirely if scream heard
    # ----------------------------------------------------
    def eliminate_wumpus(self):
        for c in self.wumpus_probs:
            self.wumpus_probs[c] = 0.0
        self.wumpus_alive = False
