from collections import deque

class MovePlanningAgent:
    def __init__(self, width=4, height=4):
        self.width = width
        self.height = height
        self.safe_cells = set([(0, 0)])
        self.visited = set()
        self.plan = []
        self.has_gold = False
        self.directions = ["UP", "RIGHT", "DOWN", "LEFT"]

    def simulate(self, x, y, direction, action):

        if action == "TurnLeft":
            direction = self.directions[(self.directions.index(direction) - 1) % 4]

        elif action == "TurnRight":
            direction = self.directions[(self.directions.index(direction) + 1) % 4]

        elif action == "Forward":
            if direction == "UP": y += 1
            elif direction == "DOWN": y -= 1
            elif direction == "RIGHT": x += 1
            elif direction == "LEFT": x -= 1

            if not (0 <= x < self.width and 0 <= y < self.height):
                return None

        return (x, y, direction)

    def bfs(self, start, goal_cells):
        queue = deque([(start, [])])
        visited = set([start])

        while queue:
            (x, y, d), actions = queue.popleft()
            if (x, y) in goal_cells:
                return actions

            for a in ["Forward", "TurnLeft", "TurnRight"]:
                nxt = self.simulate(x, y, d, a)
                if nxt and nxt not in visited:
                    nx, ny, _ = nxt
                    if (nx, ny) in self.safe_cells:
                        visited.add(nxt)
                        queue.append((nxt, actions + [a]))

        return []
